{
  "kind": "collectionType",
  "collectionName": "guard_domains",
  "info": {
    "singularName": "domain",
    "pluralName": "domains",
    "displayName": "Domain",
    "description": "Logical grouping that owns a set of roles"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  },
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true,
      "minLength": 2,
      "regex": "^[a-z][a-z0-9_-]*$",
      "description": "Stable identifier used in import/export (e.g. 'stock', 'crm')"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "roles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::api-guard-pro.role",
      "mappedBy": "domains"
    }
  }
}
