{
  "kind": "collectionType",
  "collectionName": "guard_domains",
  "info": {
    "singularName": "domain",
    "pluralName": "domains",
    "displayName": "Domain",
    "description": "Application domain for multi-tenancy"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  },
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true,
      "minLength": 2,
      "regex": "^[a-z][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "strapiRoleType": {
      "type": "string",
      "default": "authenticated"
    },
    "matchMode": {
      "type": "enumeration",
      "enum": ["header", "query", "both"],
      "default": "header"
    },
    "matchKey": {
      "type": "string",
      "default": "x-app-name"
    }
  }
}
