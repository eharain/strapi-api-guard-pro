{
  "kind": "collectionType",
  "collectionName": "guard_resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "API resource with security rules"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  },
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "displayName": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "type": {
      "type": "enumeration",
      "enum": ["standard", "extended", "alias"],
      "default": "standard",
      "required": true
    },
    "method": {
      "type": "enumeration",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
      "required": true
    },
    "pathPattern": {
      "type": "string",
      "required": true,
      "regex": "^/.*$"
    },
    "aliasPath": {
      "type": "string",
      "regex": "^/.*$"
    },
    "contentTypeUid": {
      "type": "string"
    },
    "controllerAction": {
      "type": "string"
    },
    "isPublic": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "effect": {
      "type": "enumeration",
      "enum": ["allow", "deny"],
      "default": "allow"
    },
    "requestRules": {
      "type": "json",
      "default": {}
    },
    "responseRules": {
      "type": "json",
      "default": {}
    },
    "domain": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::api-guard-pro.domain"
    },
    "parentResource": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::api-guard-pro.resource"
    }
  }
}
