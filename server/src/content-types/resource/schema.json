{
  "kind": "collectionType",
  "collectionName": "guard_resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource",
    "description": "Strapi content-type bound resource. Owns a set of policies grouped by action."
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {
    "content-manager": { "visible": false },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "contentTypeUid": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Strapi content-type UID, e.g. 'api::product.product'. This IS the resource key."
    },
    "displayName": { "type": "string" },
    "description": { "type": "text" },
    "isActive": { "type": "boolean", "default": true },
    "policies": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "plugin::api-guard-pro.policy",
      "mappedBy": "resource"
    }
  }
}
