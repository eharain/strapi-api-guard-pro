{
  "kind": "collectionType",
  "collectionName": "guard_policies",
  "info": {
    "singularName": "policy",
    "pluralName": "policies",
    "displayName": "Policy",
    "description": "Access policy attached to a single resource action. Uniquely identified by <contentTypeUid>.<controller.action>.<policyKey>."
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {
    "content-manager": { "visible": false },
    "content-type-builder": { "visible": false }
  },
  "attributes": {
    "uid": {
      "type": "string",
      "required": true,
      "unique": true,
      "description": "Fully qualified policy id: '<contentTypeUid>.<controller.action>.<policyKey>'"
    },
    "key": {
      "type": "string",
      "required": true,
      "description": "Short policy key as authored, e.g. 'branchOwn', 'hqAccess'"
    },
    "contentTypeUid": {
      "type": "string",
      "required": true,
      "description": "Strapi content-type UID, e.g. 'api::product.product'"
    },
    "actionName": {
      "type": "string",
      "required": true,
      "description": "Strapi controller.action, e.g. 'product.find'"
    },
    "description": { "type": "text" },
    "isActive": { "type": "boolean", "default": true },
    "query": {
      "type": "json",
      "default": {},
      "description": "Read-side shaping: filters, populate, fields, sort, pagination"
    },
    "filters": {
      "type": "json",
      "default": {},
      "description": "Write-side row scoping filters"
    },
    "body": {
      "type": "json",
      "default": {},
      "description": "Write-side body overrides/forced values"
    },
    "resource": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::api-guard-pro.resource",
      "inversedBy": "policies"
    },
    "grants": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::api-guard-pro.role",
      "inversedBy": "policies"
    }
  }
}
