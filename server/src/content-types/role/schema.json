{
  "kind": "collectionType",
  "collectionName": "guard_roles",
  "info": {
    "singularName": "role",
    "pluralName": "roles",
    "displayName": "Role",
    "description": "Named role referenced by resource policy grants"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": false
    },
    "content-type-builder": {
      "visible": false
    }
  },
  "attributes": {
    "key": {
      "type": "string",
      "required": true,
      "unique": true,
      "regex": "^[a-z][a-z0-9_-]*$",
      "description": "Stable identifier used in policy.grants (e.g. 'stock_manager')"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "domain": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::api-guard-pro.domain",
      "inversedBy": "roles"
    },
    "policies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::api-guard-pro.policy",
      "mappedBy": "grants"
    },
    "users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "mappedBy": "api_guard_roles",
      "configurable": false,
      "writable": false,
      "visible": false
    }
  }
}
